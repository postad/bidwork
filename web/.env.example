# Copy to web/.env.local and fill in. See ../.env.example for the full var reference.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Trigger.dev (engine jobs). Project ref lives in trigger.config.ts (not secret).
# Dev key (tr_dev_...) here; prod key (tr_prod_...) goes in Vercel env.
TRIGGER_SECRET_KEY=tr_dev_...

# Anthropic (engine: Haiku triage + Opus extraction)
ANTHROPIC_API_KEY=sk-ant-...
