# ─────────────────────────────────────────────────────────────
# BidWork — environment variable reference (safe to commit)
# Copy what you need into the real secret file. Do NOT put secrets here.
#   • spike scripts read the project-root  .env
#   • the Next.js app reads  web/.env.local  (Next convention)
# ─────────────────────────────────────────────────────────────

# ── Anthropic (engine: Haiku triage + Opus extraction) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase (cloud project) ──
# Public (safe in the browser): URL + anon key
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server only — NEVER expose to the client. Bypasses RLS (workers / server actions).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Trigger.dev (background engine jobs) ──
TRIGGER_SECRET_KEY=tr_...
TRIGGER_PROJECT_ID=proj_...

# ── Mailgun (bids + outreach, separate subdomains) ──
MAILGUN_API_KEY=
MAILGUN_BID_DOMAIN=bid.yourdomain.com
MAILGUN_OUTREACH_DOMAIN=hello.yourdomain.com
MAILGUN_WEBHOOK_SIGNING_KEY=

# ── Stripe (Stage 5 billing) ──
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
